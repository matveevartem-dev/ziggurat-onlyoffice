APP_ENV=dev

LOCAL_INTERFACE_IP=192.168.1.37

HTTP_PORT=880
SSL_PORT=8443

DOMAIN_URL=tcrm.test
SITE_NAME=tcrm.test
ONLYOFFICE_NAME=onlyoffice.tcrm.test

BASE_VERSION=24.04
BASE_IMAGE=ubuntu:$BASE_VERSION

#OPENSSL_CONF=/etc/ssl/openssl.cnf

OS_CERTIFICATE_PATH=/etc/ssl/certs/${ONLYOFFICE_NAME}/fullchain.pem
OS_CRT_PATH=/etc/ssl/certs/${ONLYOFFICE_NAME}/fullchain.pem
OS_KEY_PATH=/etc/ssl/private/${ONLYOFFICE_NAME}/privkey.pem
OS_DHPARAM_PATH=/etc/ssl/certs/${ONLYOFFICE_NAME}/dhparam.pem

SSL_CERTIFICATE_PATH=/var/www/onlyoffice/Data/certs/${ONLYOFFICE_NAME}.crt
SSL_CRT_PATH=/var/www/onlyoffice/Data/certs/${ONLYOFFICE_NAME}.crt
SSL_KEY_PATH=/var/www/onlyoffice/Data/certs/${ONLYOFFICE_NAME}.key
SSL_DHPARAM_PATH=/var/www/onlyoffice/Data/certs/${ONLYOFFICE_NAME}.pem

# Адрес твоего OnlyOffice Document Server
NUXT_PUBLIC_ONLYOFFICE_API_URL=https://tcrm.test

# Публичный адрес твоего бэкенда, где лежат файлы (uploads)
NUXT_PUBLIC_STORAGE_BASE_URL=http://192.168.1.37:380