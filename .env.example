APP_ENV=dev

LOCAL_INTERFACE_IP=192.168.1.10

HTTP_PORT=780
SSL_PORT=7443

DOMAIN_URL=tcrm.test
SITE_NAME=tcrm.test
ONLYOFFICE_NAME=onlyoffice.tcrm.test

BASE_VERSION=24.04
BASE_IMAGE=ubuntu:$BASE_VERSION

OS_CERTIFICATE_PATH=/etc/ssl/certs/${ONLYOFFICE_NAME}/fullchain.pem
OS_CRT_PATH=/etc/ssl/certs/${ONLYOFFICE_NAME}/fullchain.pem
OS_KEY_PATH=/etc/ssl/private/${ONLYOFFICE_NAME}/privkey.pem
OS_DHPARAM_PATH=/etc/ssl/certs/${ONLYOFFICE_NAME}/dhparam.pem

SSL_CERTIFICATE_PATH=/var/www/onlyoffice/Data/certs/${ONLYOFFICE_NAME}/fullchain.pem
SSL_CRT_PATH=/var/www/onlyoffice/Data/certs/${ONLYOFFICE_NAME}/fullchain.pem
SSL_KEY_PATH=/var/www/onlyoffice/Data/certs/${ONLYOFFICE_NAME}/privkey.pem
SSL_DHPARAM_PATH=/var/www/onlyoffice/Data/certs/${ONLYOFFICE_NAME}/dhparam.pem
