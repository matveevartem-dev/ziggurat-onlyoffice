$TTL 86400
; ==============================================================================
#  [Ziggurat OS] ISOLATED SUBDOMAIN AUTHORITATIVE SPECIFICATION (v1732)
#  FQDN Path Target: onlyoffice.ziggurat.ae
; ==============================================================================
@   IN  SOA ns1.onlyoffice.ziggurat.ae. admin.onlyoffice.ziggurat.ae. (
            2026062401 ; Serial (Текущая дата верификации)
            3600       ; Refresh
            1800       ; Retry
            604800     ; Expire
            86400 )    ; Minimum TTL

; Фиксируем авторитетные сервера имен для изолированного поддомена
@   IN  NS  ns1.onlyoffice.ziggurat.ae.

; Нативно мапим имя ns1 и сам поддомен onlyoffice.ziggurat.ae на IP-адрес ингресс-шлюза Nginx
ns1 IN  A   172.23.0.1
@   IN  A   172.23.0.1
